# NPC Translator PDF Ollama Backend

# Ollama locale
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2

# Binario pdf2zh. Se installato nel venv, lascia pdf2zh.
PDF2ZH_BIN=pdf2zh

# CORS frontend ammessi
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8000,http://127.0.0.1:8000,https://dal1312.github.io

# Limiti
MAX_UPLOAD_MB=80
PDF_TRANSLATE_TIMEOUT_SEC=3600
