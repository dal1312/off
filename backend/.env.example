# NPC Translator Live Backend
# Copia questo file in .env quando lavori in locale.

# Obbligatoria per la modalità backend OpenAI
OPENAI_API_KEY=sk-your-key-here

# Origini autorizzate, separate da virgola se sono più di una
ALLOWED_ORIGIN=https://dal1312.github.io,http://localhost:5173,http://localhost:8787

# Render imposta PORT automaticamente. In locale puoi usare 8787.
PORT=8787
HOST=0.0.0.0

# Modelli configurabili
STT_MODEL=gpt-4o-mini-transcribe
TRANSLATE_MODEL=gpt-4.1-mini
