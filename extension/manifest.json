{
  "manifest_version": 3,
  "name": "NPC YouTube Caption Translator",
  "version": "0.3.0",
  "description": "Legge i sottotitoli YouTube, li traduce e pronuncia l'italiano con coda audio stabile.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://api.mymemory.translated.net/*",
    "https://translate.googleapis.com/*",
    "https://lingva.ml/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "NPC YouTube Translator",
    "default_popup": "popup.html"
  }
}
